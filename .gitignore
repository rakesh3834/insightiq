.venv/
__pycache__/
.pytest_cache/
*.pyc
.env
.env.local
logs/*.log

# frontend build / deps (regenerated by `npm install` / `next build`)
node_modules/
.next/
frontend/.env.local
frontend/tsconfig.tsbuildinfo

# OS cruft
.DS_Store

# warehouse and vector DB — too large for git, regenerated on startup
artifacts/*.sqlite
artifacts/*.duckdb
artifacts/chroma/
artifacts/warehouse_export/

# keep all generated artifact files in git so Streamlit Cloud can read them
!artifacts/.gitkeep
