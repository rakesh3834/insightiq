APP_ENV=local
ARTIFACTS_DIR=artifacts
HF_TOKEN=replace_with_your_huggingface_token
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
INSIGHTIQ_REBUILD_ON_START=true

# Advanced ML (Hugging Face Inference API). Set the *_USE_* flags to false to
# force the fast deterministic fallbacks (hash embeddings / lexicon sentiment).
INSIGHTIQ_USE_HF_EMBEDDINGS=true
INSIGHTIQ_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
INSIGHTIQ_USE_HF_SENTIMENT=true
INSIGHTIQ_SENTIMENT_MODEL=distilbert/distilbert-base-uncased-finetuned-sst-2-english
INSIGHTIQ_SENTIMENT_MAX_HF=3000

