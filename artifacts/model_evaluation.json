  "business_case": {
    "problem": "Orders cancel after checkout, leaking revenue and burning fulfilment cost on orders that never complete.",
    "why_this_model": "Cancellation is a pre-fulfilment decision: a calibrated per-order risk score lets ops intervene (verify payment, prioritise support, hold shipment) before the revenue is lost. Logistic Regression wins on cross-validated AUC, scores in <1ms, and yields calibrated probabilities ops can act on.",
    "decision_enabled": "Flag high-risk orders for a proactive save-intervention at the F1-optimal threshold.",
    "primary_metric": "Cancellation rate \u2192 recovered GMV",
